# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Specify a different Groq model
# GROQ_MODEL_NAME=llama-3.1-8b-instant

# ============================================================================
# LangSmith Configuration (Optional - for Observability & Monitoring)
# ============================================================================
# Get your API key from: https://smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_api_key_here

# Project name for organizing traces (default: medical-chatbot)
# LANGSMITH_PROJECT=medical-chatbot

# Enable/disable tracing (default: true when API key is set)
# LANGCHAIN_TRACING_V2=true

# Optional: Custom LangSmith endpoint
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
